{
  "name": "Pharma DBMS Development",
  "dockerComposeFile": ["../compose.yaml", "../compose.dev.yaml"],
  "service": "django",
  "workspaceFolder": "/usr/src",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "mjmcloug.django-template-indent",
        "batisteo.vscode-django",
        "ms-vscode.makefile-tools",
        "eamodio.gitlens",
        "ms-vscode.rest-client",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/dbms-django-dev/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": false,
        "python.formatting.provider": "none",
        "ruff.importStrategy": "fromEnvironment",
        "ruff.lint.args": ["--line-length=120"],
        "files.exclude": {
          "**/__pycache__": true,
          "**/*.pyc": true,
          "**/.pytest_cache": true,
          "**/.mypy_cache": true
        }
      }
    }
  },

  "forwardPorts": [8000, 8888, 5432, 80],
  "portsAttributes": {
    "8000": {
      "label": "Django",
      "onAutoForward": "notify"
    },
    "8888": {
      "label": "Jupyter Lab",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "80": {
      "label": "Nginx",
      "onAutoForward": "notify"
    }
  },

  "postCreateCommand": "mamba run --name dbms-django-dev bash -c 'python manage.py makemigrations accounts && python manage.py migrate accounts && python manage.py migrate && python manage.py collectstatic --noinput'",

  "postStartCommand": "bash -c 'source /opt/conda/etc/profile.d/conda.sh && conda activate dbms-django-dev'",

  "remoteEnv": {
    "TZ": "Asia/Tokyo"
  },

  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached"
  ],

  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },

  "overrideCommand": false,
  "userEnvProbe": "loginInteractiveShell"
}
